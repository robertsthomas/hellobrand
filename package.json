{
  "name": "hellobrand",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "doppler run -- next dev --turbopack -p 3011",
    "dev:next": "next dev --turbopack -p 3011",
    "dev:webpack": "doppler run -- next dev -p 3011",
    "dev:next:webpack": "next dev -p 3011",
    "build": "next build",
    "build:prd": "doppler run --config prd -- next build",
    "start": "next start",
    "start:prd": "doppler run --config prd -- next start",
    "start:dev": "doppler run --config dev -- next start",
    "document-worker": "tsx scripts/document-processing-worker.ts",
    "document-worker:once": "tsx scripts/document-processing-worker.ts --once",
    "db:migrate": "doppler run -- pnpm exec prisma migrate dev",
    "inngest:dev": "pnpm dlx inngest-cli@latest dev",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:all": "./scripts/run-tests.sh",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:server": "HELLOBRAND_E2E_ENABLED=1 HELLOBRAND_E2E_AUTH_SECRET=hellobrand-playwright-local HELLOBRAND_DEV_PLAN=basic next dev --turbopack --port 4011"
  },

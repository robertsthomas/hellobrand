{
  "name": "hellobrand",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "doppler run -- next dev --turbopack -p 3011",
    "dev:next": "next dev --turbopack -p 3011",
    "dev:webpack": "doppler run -- next dev -p 3011",
    "dev:next:webpack": "next dev -p 3011",
    "build": "next build",
    "build:prd": "doppler run --config prd -- next build",
    "start": "next start",
    "start:prd": "doppler run --config prd -- next start",
    "start:dev": "doppler run --config dev -- next start",
    "db:migrate": "doppler run -- pnpm exec prisma migrate dev",
    "inngest:dev": "pnpm dlx inngest-cli@latest dev",
    "inngest:worker": "pnpm exec tsx scripts/inngest-worker.ts",
    "inngest:worker:dev": "INNGEST_DEV=1 pnpm exec tsx scripts/inngest-worker.ts",
    "lint": "biome lint . && node scripts/check-architecture.mjs",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:all": "./scripts/run-tests.sh",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:server": "HELLOBRAND_E2E_ENABLED=1 HELLOBRAND_E2E_AUTH_SECRET=hellobrand-playwright-local HELLOBRAND_DEV_PLAN=free next dev --turbopack --port 4011"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.118",
    "@azure-rest/ai-document-intelligence": "^1.1.0",
    "@clerk/nextjs": "^7.0.7",
    "@inngest/middleware-sentry": "^1.0.0",
    "@launchdarkly/node-server-sdk": "^9.10.11",
    "@openrouter/ai-sdk-provider": "^2.3.3",
    "@prisma/client": "^6.19.2",
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@sentry/nextjs": "^10.47.0",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.49.1",
    "ai": "^6.0.116",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "framer-motion": "^12.38.0",
    "imapflow": "^1.2.18",
    "inngest": "^4.2.4",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.511.0",
    "mailparser": "^3.9.6",
    "mammoth": "^1.9.0",
    "next": "^16.1.7",
    "next-intl": "^4.9.1",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.4",
    "openai": "^4.91.1",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^5.5.207",
    "posthog-js": "^1.363.6",
    "posthog-node": "^5.28.6",
    "react": "19",
    "react-dom": "19",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.10.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.2.0",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "stripe": "20.4.1",
    "tailwind-merge": "^3.3.1",
    "zod": "^3.24.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@playwright/test": "^1.51.1",
    "@tailwindcss/forms": "^0.5.10",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^22.13.10",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.20",
    "dotenv": "^17.4.2",
    "postcss": "^8.5.3",
    "prisma": "^6.19.2",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}

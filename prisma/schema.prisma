generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlanTier {
  basic
  standard
  premium
}

enum BillingProvider {
  stripe
}

enum BillingInterval {
  month
  year
}

enum BillingSubscriptionStatus {
  incomplete
  incomplete_expired
  trialing
  active
  past_due
  canceled
  unpaid
  paused
}

enum BillingTrialStatus {
  granted
  active
  converted
  expired
  canceled
  revoked
}

enum BillingWebhookEventStatus {
  pending
  processing
  processed
  ignored
  failed
}

model User {
  id          String   @id
  email       String   @unique
  displayName String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  profile               Profile?
  intakeSessions        IntakeSession[]
  intakeBatches         IntakeBatch[]
  deals                 Deal[]
  emailAccounts         ConnectedEmailAccount[]
  emailCandidateMatches EmailDealCandidateMatch[]
  emailDealEvents       EmailDealEvent[]
  emailTermSuggestions  EmailDealTermSuggestion[]
  emailActionItems      EmailActionItem[]
  brandContacts         BrandContact[]
  assistantThreads      AssistantThread[]
  assistantSnapshots    AssistantContextSnapshot[]
  billingAccount        BillingAccount?
  onboardingState       UserOnboardingState?
  appNotifications      AppNotification[]
  notificationEmailDeliveries NotificationEmailDelivery[]
}

model Deal {
  id                  String    @id @default(uuid())
  userId              String
  brandName           String
  campaignName        String
  status              String
  paymentStatus       String
  countersignStatus   String
  summary             String?
  legalDisclaimer     String
  nextDeliverableDate DateTime?
  analyzedAt          DateTime?
  confirmedAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user                  User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  intakeSession         IntakeSession?
  paymentRecord         PaymentRecord?
  documents             Document[]
  terms                 DealTerms?
  riskFlags             RiskFlag[]
  emailDrafts           EmailDraft[]
  assistantThreads      AssistantThread[]
  assistantSnapshots    AssistantContextSnapshot[]
  jobs                  Job[]
  summaries             Summary[]
  emailLinks            DealEmailLink[]
  emailCandidateMatches EmailDealCandidateMatch[]
  emailDealEvents       EmailDealEvent[]
  emailTermSuggestions  EmailDealTermSuggestion[]
  emailActionItems      EmailActionItem[]
  brandContacts         BrandContact[]
  appNotifications      AppNotification[]
}

model Document {
  id                       String   @id @default(uuid())
  dealId                   String
  userId                   String
  fileName                 String
  mimeType                 String
  storagePath              String
  processingStatus         String
  rawText                  String?
  normalizedText           String?
  documentKind             String
  classificationConfidence Float?
  sourceType               String
  errorMessage             String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  deal             Deal                 @relation(fields: [dealId], references: [id], onDelete: Cascade)
  sections         DocumentSection[]
  extractionResult ExtractionResult?
  evidence         ExtractionEvidence[]
  summaries        Summary[]
  jobs             Job[]
  intakeDocument   IntakeDocument?

  @@index([dealId])
}

model DocumentSection {
  id         String   @id @default(uuid())
  documentId String
  title      String
  content    String
  chunkIndex Int
  pageRange  String?
  createdAt  DateTime @default(now())

  document Document             @relation(fields: [documentId], references: [id], onDelete: Cascade)
  evidence ExtractionEvidence[]

  @@index([documentId, chunkIndex])
}

model ExtractionResult {
  id            String   @id @default(uuid())
  documentId    String   @unique
  schemaVersion String
  model         String
  data          Json
  confidence    Float?
  conflicts     Json
  createdAt     DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

model ExtractionEvidence {
  id         String   @id @default(uuid())
  documentId String
  fieldPath  String
  snippet    String
  sectionId  String?
  confidence Float?
  createdAt  DateTime @default(now())

  document Document         @relation(fields: [documentId], references: [id], onDelete: Cascade)
  section  DocumentSection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)

  @@index([documentId])
}

model Summary {
  id         String   @id @default(uuid())
  dealId     String
  documentId String?
  body       String
  version    String
  createdAt  DateTime @default(now())

  deal     Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  document Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)

  @@index([dealId])
}

model AssistantThread {
  id        String   @id @default(uuid())
  userId    String
  dealId    String?
  scope     String
  title     String
  summary   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  deal     Deal?              @relation(fields: [dealId], references: [id], onDelete: Cascade)
  messages AssistantMessage[]

  @@index([userId, updatedAt])
  @@index([dealId, updatedAt])
}

model AssistantMessage {
  id        String   @id @default(uuid())
  threadId  String
  role      String
  content   String
  parts     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  thread AssistantThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}

model AssistantContextSnapshot {
  id        String   @id @default(uuid())
  userId    String
  dealId    String?
  scope     String
  key       String
  version   String
  summary   String
  payload   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  deal Deal? @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([dealId, scope])
}

model DealTerms {
  id                        String   @id @default(uuid())
  dealId                    String   @unique
  brandName                 String?
  agencyName                String?
  creatorName               String?
  campaignName              String?
  paymentAmount             Float?
  currency                  String?
  paymentTerms              String?
  paymentStructure          String?
  netTermsDays              Int?
  paymentTrigger            String?
  deliverables              Json
  usageRights               String?
  usageRightsOrganicAllowed Boolean?
  usageRightsPaidAllowed    Boolean?
  whitelistingAllowed       Boolean?
  usageDuration             String?
  usageTerritory            String?
  usageChannels             Json
  exclusivity               String?
  exclusivityApplies        Boolean?
  exclusivityCategory       String?
  exclusivityDuration       String?
  exclusivityRestrictions   String?
  brandCategory             String?
  competitorCategories      Json
  restrictedCategories      Json
  campaignDateWindow        Json?
  disclosureObligations     Json
  revisions                 String?
  revisionRounds            Int?
  termination               String?
  terminationAllowed        Boolean?
  terminationNotice         String?
  terminationConditions     String?
  governingLaw              String?
  notes                     String?
  manuallyEditedFields      Json     @default("[]")
  briefData                 Json?
  pendingExtraction         Json?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)
}

model RiskFlag {
  id               String   @id @default(uuid())
  dealId           String
  category         String
  title            String
  detail           String
  severity         String
  suggestedAction  String?
  evidence         Json
  sourceDocumentId String?
  sourceType       String?
  sourceMessageId  String?
  createdAt        DateTime @default(now())

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
}

model EmailDraft {
  id        String   @id @default(uuid())
  dealId    String
  intent    String
  subject   String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@unique([dealId, intent])
  @@index([dealId])
}

model ConnectedEmailAccount {
  id                    String    @id @default(uuid())
  userId                String
  provider              String
  providerAccountId     String
  emailAddress          String
  displayName           String?
  status                String
  scopes                Json
  accessTokenEncrypted  String?
  refreshTokenEncrypted String?
  tokenExpiresAt        DateTime?
  lastSyncAt            DateTime?
  lastErrorCode         String?
  lastErrorMessage      String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  threads   EmailThread[]
  syncState EmailSyncState?

  @@unique([userId, provider, providerAccountId])
  @@index([userId, provider, status])
}

model EmailThread {
  id                 String    @id @default(uuid())
  accountId          String
  provider           String
  providerThreadId   String
  subject            String
  snippet            String?
  participantsJson   Json
  lastMessageAt      DateTime
  messageCount       Int       @default(0)
  isContractRelated  Boolean   @default(false)
  aiSummary          String?
  aiSummaryUpdatedAt DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  account          ConnectedEmailAccount     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  messages         EmailMessage[]
  dealLinks        DealEmailLink[]
  candidateMatches EmailDealCandidateMatch[]
  dealEvents       EmailDealEvent[]
  termSuggestions  EmailDealTermSuggestion[]
  actionItems      EmailActionItem[]

  @@unique([accountId, providerThreadId])
  @@index([accountId, lastMessageAt])
}

model EmailMessage {
  id                String    @id @default(uuid())
  threadId          String
  providerMessageId String
  internetMessageId String?
  fromJson          Json
  toJson            Json
  ccJson            Json
  bccJson           Json
  subject           String
  textBody          String?
  htmlBody          String?
  sentAt            DateTime?
  receivedAt        DateTime?
  direction         String
  hasAttachments    Boolean   @default(false)
  rawStorageKey     String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  thread          EmailThread               @relation(fields: [threadId], references: [id], onDelete: Cascade)
  attachments     EmailAttachment[]
  dealEvents      EmailDealEvent[]
  termSuggestions EmailDealTermSuggestion[]
  actionItems     EmailActionItem[]

  @@unique([threadId, providerMessageId])
  @@index([threadId, receivedAt])
}

model EmailAttachment {
  id                   String   @id @default(uuid())
  messageId            String
  providerAttachmentId String
  filename             String
  mimeType             String
  sizeBytes            Int
  storageKey           String?
  extractedText        String?
  createdAt            DateTime @default(now())

  message EmailMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, providerAttachmentId])
  @@index([messageId])
}

model EmailSyncState {
  id                     String    @id @default(uuid())
  accountId              String    @unique
  providerCursor         String?
  providerSubscriptionId String?
  subscriptionExpiresAt  DateTime?
  lastHistoryId          String?
  lastSuccessfulSyncAt   DateTime?
  lastErrorAt            DateTime?
  lastErrorCode          String?
  lastErrorMessage       String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  account ConnectedEmailAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model DealEmailLink {
  id         String   @id @default(uuid())
  dealId     String
  threadId   String
  linkSource String
  confidence Float?
  createdAt  DateTime @default(now())

  deal   Deal        @relation(fields: [dealId], references: [id], onDelete: Cascade)
  thread EmailThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@unique([dealId, threadId])
  @@index([threadId])
}

model EmailDealCandidateMatch {
  id           String    @id @default(uuid())
  userId       String
  dealId       String
  threadId     String
  status       String
  confidence   Float
  reasonsJson  Json
  evidenceJson Json
  reviewedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  deal   Deal        @relation(fields: [dealId], references: [id], onDelete: Cascade)
  thread EmailThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@unique([dealId, threadId])
  @@index([userId, status, updatedAt])
  @@index([threadId])
}

model EmailDealEvent {
  id           String   @id @default(uuid())
  userId       String
  dealId       String
  threadId     String
  messageId    String
  category     String
  title        String
  body         String
  metadataJson Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  deal    Deal         @relation(fields: [dealId], references: [id], onDelete: Cascade)
  thread  EmailThread  @relation(fields: [threadId], references: [id], onDelete: Cascade)
  message EmailMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([dealId, messageId, category])
  @@index([userId, dealId, createdAt])
  @@index([threadId, createdAt])
}

model EmailDealTermSuggestion {
  id           String   @id @default(uuid())
  userId       String
  dealId       String
  threadId     String
  messageId    String
  status       String
  title        String
  summary      String
  patchJson    Json
  evidenceJson Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  deal    Deal         @relation(fields: [dealId], references: [id], onDelete: Cascade)
  thread  EmailThread  @relation(fields: [threadId], references: [id], onDelete: Cascade)
  message EmailMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([dealId, messageId])
  @@index([userId, dealId, status, createdAt])
  @@index([threadId, status, createdAt])
}

model EmailActionItem {
  id         String    @id @default(uuid())
  userId     String
  dealId     String
  threadId   String
  messageId  String
  action     String
  dueDate    DateTime?
  urgency    String
  status     String
  sourceText String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  deal    Deal         @relation(fields: [dealId], references: [id], onDelete: Cascade)
  thread  EmailThread  @relation(fields: [threadId], references: [id], onDelete: Cascade)
  message EmailMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([dealId, messageId, action])
  @@index([userId, dealId, status, createdAt])
  @@index([userId, status, dueDate])
  @@index([threadId])
}

model BrandContact {
  id           String    @id @default(uuid())
  userId       String
  dealId       String
  name         String
  email        String
  organization String?
  inferredRole String?
  lastSeenAt   DateTime?
  messageCount Int       @default(1)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@unique([userId, dealId, email])
  @@index([userId, dealId])
}

model Job {
  id            String   @id @default(uuid())
  dealId        String
  documentId    String
  type          String
  status        String
  attemptCount  Int      @default(0)
  failureReason String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  deal     Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([dealId, documentId])
}

model Profile {
  id                      String   @id @default(uuid())
  userId                  String   @unique
  displayName             String?
  creatorLegalName        String?
  businessName            String?
  contactEmail            String?
  preferredSignature      String?
  payoutDetails           String?
  defaultCurrency         String?
  reminderLeadDays        Int?
  conflictAlertsEnabled   Boolean  @default(true)
  paymentRemindersEnabled Boolean  @default(true)
  emailNotificationsEnabled Boolean @default(false)
  accentColor             String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  auditEvents ProfileAuditEvent[]
}

model ProfileAuditEvent {
  id            String   @id @default(uuid())
  profileId     String
  actorUserId   String
  changedFields Json
  snapshot      Json
  createdAt     DateTime @default(now())

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, createdAt])
}

model UserOnboardingState {
  id                           String    @id @default(uuid())
  userId                       String    @unique
  profileOnboardingCompletedAt DateTime?
  profileOnboardingVersion     Int       @default(0)
  profileOnboardingStateJson   Json?
  productGuideVersion          Int       @default(0)
  productGuideStateJson        Json?
  createdAt                    DateTime  @default(now())
  updatedAt                    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AppNotification {
  id           String   @id @default(uuid())
  userId       String
  category     String
  eventType    String
  entityType   String
  entityId     String
  sessionId    String?
  dealId       String?
  title        String
  body         String
  href         String
  status       String   @default("active")
  readAt       DateTime?
  clearedAt    DateTime?
  supersededAt DateTime?
  dedupeKey    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user          User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  deal          Deal?                      @relation(fields: [dealId], references: [id], onDelete: SetNull)
  emailDelivery NotificationEmailDelivery?

  @@unique([userId, dedupeKey])
  @@index([userId, status, createdAt])
  @@index([userId, readAt, createdAt])
  @@index([userId, clearedAt, createdAt])
  @@index([sessionId, status, createdAt])
  @@index([dealId, status, createdAt])
}

model NotificationEmailDelivery {
  id                String   @id @default(uuid())
  appNotificationId String   @unique
  userId            String
  recipientEmail    String
  provider          String
  providerMessageId String?
  status            String
  errorMessage      String?
  sentAt            DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  appNotification AppNotification @relation(fields: [appNotificationId], references: [id], onDelete: Cascade)
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, createdAt])
}

model IntakeSession {
  id                   String    @id @default(uuid())
  userId               String
  dealId               String    @unique
  status               String
  errorMessage         String?
  inputSource          String?
  draftBrandName       String?
  draftCampaignName    String?
  draftNotes           String?
  draftPastedText      String?
  draftPastedTextTitle    String?
  duplicateCheckStatus    String?
  duplicateMatchJson      Json?
  completedAt             DateTime?
  expiresAt               DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  deal       Deal              @relation(fields: [dealId], references: [id], onDelete: Cascade)
  documents  IntakeDocument[]
  batchGroup IntakeBatchGroup?

  @@index([userId, status])
}

model IntakeDocument {
  id              String   @id @default(uuid())
  intakeSessionId String
  documentId      String   @unique
  createdAt       DateTime @default(now())

  intakeSession IntakeSession @relation(fields: [intakeSessionId], references: [id], onDelete: Cascade)
  document      Document      @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([intakeSessionId])
}

model PaymentRecord {
  id          String    @id @default(uuid())
  dealId      String    @unique
  amount      Float?
  currency    String?
  invoiceDate DateTime?
  dueDate     DateTime?
  paidDate    DateTime?
  status      String
  notes       String?
  source      String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)
}

model BillingAccount {
  id                        String                     @id @default(uuid())
  userId                    String                     @unique
  provider                  BillingProvider            @default(stripe)
  billingEmail              String?
  stripeCustomerId          String?                    @unique
  currentPlanTier           PlanTier?
  currentPlanInterval       BillingInterval?
  currentSubscriptionStatus BillingSubscriptionStatus?
  currentTrialPlanTier      PlanTier?
  currentTrialStartedAt     DateTime?
  currentTrialEndsAt        DateTime?
  currentPeriodStart        DateTime?
  currentPeriodEnd          DateTime?
  cancelAtPeriodEnd         Boolean                    @default(false)
  lastSyncedAt              DateTime?
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt

  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptions BillingSubscription[]
  trialLedgers  BillingTrialLedger[]
  usageLedgers  BillingUsageLedger[]
  webhookEvents BillingWebhookEvent[]

  @@index([currentPlanTier, currentSubscriptionStatus])
}

model BillingSubscription {
  id                      String                    @id @default(uuid())
  billingAccountId        String
  provider                BillingProvider           @default(stripe)
  planTier                PlanTier
  interval                BillingInterval
  status                  BillingSubscriptionStatus
  stripeSubscriptionId    String?                   @unique
  stripeCustomerId        String?
  stripeProductId         String?
  stripePriceId           String?
  stripeCheckoutSessionId String?
  startedAt               DateTime?
  currentPeriodStart      DateTime?
  currentPeriodEnd        DateTime?
  trialStartedAt          DateTime?
  trialEndsAt             DateTime?
  cancelAtPeriodEnd       Boolean                   @default(false)
  canceledAt              DateTime?
  endedAt                 DateTime?
  latestInvoiceId         String?
  metadataJson            Json?
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt

  billingAccount BillingAccount       @relation(fields: [billingAccountId], references: [id], onDelete: Cascade)
  trialLedgers   BillingTrialLedger[]

  @@index([billingAccountId, status, createdAt])
  @@index([stripeCustomerId])
}

model BillingTrialLedger {
  id                    String             @id @default(uuid())
  billingAccountId      String
  billingSubscriptionId String?
  planTier              PlanTier
  source                String
  status                BillingTrialStatus
  startedAt             DateTime
  endsAt                DateTime
  convertedAt           DateTime?
  expiredAt             DateTime?
  canceledAt            DateTime?
  metadataJson          Json?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  billingAccount      BillingAccount       @relation(fields: [billingAccountId], references: [id], onDelete: Cascade)
  billingSubscription BillingSubscription? @relation(fields: [billingSubscriptionId], references: [id], onDelete: SetNull)

  @@index([billingAccountId, planTier, status])
  @@index([billingSubscriptionId])
  @@index([endsAt])
}

model BillingUsageLedger {
  id               String    @id @default(uuid())
  billingAccountId String
  featureKey       String
  windowKey        String
  quantity         Int       @default(0)
  limit            Int?
  periodStart      DateTime?
  periodEnd        DateTime?
  metadataJson     Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  billingAccount BillingAccount @relation(fields: [billingAccountId], references: [id], onDelete: Cascade)

  @@unique([billingAccountId, featureKey, windowKey])
  @@index([billingAccountId, periodEnd])
}

model BillingWebhookEvent {
  id               String                    @id @default(uuid())
  billingAccountId String?
  provider         BillingProvider           @default(stripe)
  stripeEventId    String                    @unique
  stripeEventType  String
  apiVersion       String?
  livemode         Boolean                   @default(false)
  status           BillingWebhookEventStatus @default(pending)
  processingRuns   Int                       @default(0)
  lastReceivedAt   DateTime                  @default(now())
  processedAt      DateTime?
  errorMessage     String?
  payloadJson      Json?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  billingAccount BillingAccount? @relation(fields: [billingAccountId], references: [id], onDelete: SetNull)

  @@index([billingAccountId, createdAt])
  @@index([status, updatedAt])
}

model IntakeBatch {
  id        String   @id @default(uuid())
  userId    String
  status    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  groups IntakeBatchGroup[]

  @@index([userId])
}

model IntakeBatchGroup {
  id              String   @id @default(uuid())
  batchId         String
  intakeSessionId String?  @unique
  label           String
  confidence      Float?
  documentIds     Json
  status          String
  createdAt       DateTime @default(now())

  batch         IntakeBatch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  intakeSession IntakeSession? @relation(fields: [intakeSessionId], references: [id], onDelete: SetNull)

  @@index([batchId])
}

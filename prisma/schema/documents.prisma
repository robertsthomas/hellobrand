// Document ingestion, extraction, and review pipeline records.

model Document {
  id                       String    @id @default(uuid())
  dealId                   String
  userId                   String
  fileName                 String
  mimeType                 String
  storagePath              String
  fileSizeBytes            Int?
  checksumSha256           String?
  processingStatus         String
  rawText                  String?
  normalizedText           String?
  documentKind             String
  classificationConfidence Float?
  sourceType               String
  errorMessage             String?
  processingRunId          String?
  processingRunStateJson   Json?
  processingStartedAt      DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  deal             Deal                    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  sections         DocumentSection[]
  extractionResult ExtractionResult?
  evidence         ExtractionEvidence[]
  runs             DocumentRun[]
  artifacts        DocumentArtifact[]
  fieldEvidence    DocumentFieldEvidence[]
  reviewItems      DocumentReviewItem[]
  summaries        Summary[]
  jobs             Job[]
  intakeDocument   IntakeDocument?

  @@index([dealId])
}

model DocumentSection {
  id         String   @id @default(uuid())
  documentId String
  title      String
  content    String
  chunkIndex Int
  pageRange  String?
  createdAt  DateTime @default(now())

  document      Document                @relation(fields: [documentId], references: [id], onDelete: Cascade)
  evidence      ExtractionEvidence[]
  fieldEvidence DocumentFieldEvidence[]
  reviewItems   DocumentReviewItem[]

  @@index([documentId, chunkIndex])
}

model ExtractionResult {
  id            String   @id @default(uuid())
  documentId    String   @unique
  schemaVersion String
  model         String
  data          Json
  confidence    Float?
  conflicts     Json
  createdAt     DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

model ExtractionEvidence {
  id         String   @id @default(uuid())
  documentId String
  fieldPath  String
  snippet    String
  sectionId  String?
  confidence Float?
  createdAt  DateTime @default(now())

  document Document         @relation(fields: [documentId], references: [id], onDelete: Cascade)
  section  DocumentSection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)

  @@index([documentId])
}

model DocumentRun {
  id             String    @id
  documentId     String
  status         String
  stepStateJson  Json
  startedAt      DateTime?
  completedAt    DateTime?
  failedAt       DateTime?
  failureMessage String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  document      Document                @relation(fields: [documentId], references: [id], onDelete: Cascade)
  artifacts     DocumentArtifact[]
  fieldEvidence DocumentFieldEvidence[]
  reviewItems   DocumentReviewItem[]

  @@index([documentId, createdAt])
  @@index([documentId, updatedAt])
}

model DocumentArtifact {
  id         String   @id @default(uuid())
  documentId String
  runId      String
  step       String
  kind       String
  processor  String?
  payload    Json?
  createdAt  DateTime @default(now())

  document      Document                @relation(fields: [documentId], references: [id], onDelete: Cascade)
  run           DocumentRun             @relation(fields: [runId], references: [id], onDelete: Cascade)
  fieldEvidence DocumentFieldEvidence[]
  reviewItems   DocumentReviewItem[]

  @@index([documentId, runId, createdAt])
  @@index([runId, step, kind])
}

model DocumentFieldEvidence {
  id         String   @id @default(uuid())
  documentId String
  runId      String
  fieldPath  String
  snippet    String
  sourceType String
  sectionId  String?
  artifactId String?
  confidence Float?
  createdAt  DateTime @default(now())

  document Document          @relation(fields: [documentId], references: [id], onDelete: Cascade)
  run      DocumentRun       @relation(fields: [runId], references: [id], onDelete: Cascade)
  section  DocumentSection?  @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  artifact DocumentArtifact? @relation(fields: [artifactId], references: [id], onDelete: SetNull)

  @@index([documentId, fieldPath, createdAt])
  @@index([runId, fieldPath, createdAt])
}

model DocumentReviewItem {
  id             String   @id @default(uuid())
  documentId     String
  runId          String
  fieldPath      String
  status         String
  reason         String
  title          String
  detail         String
  confidence     Float?
  suggestedValue Json?
  currentValue   Json?
  sectionId      String?
  artifactId     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  document Document          @relation(fields: [documentId], references: [id], onDelete: Cascade)
  run      DocumentRun       @relation(fields: [runId], references: [id], onDelete: Cascade)
  section  DocumentSection?  @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  artifact DocumentArtifact? @relation(fields: [artifactId], references: [id], onDelete: SetNull)

  @@index([documentId, status, createdAt])
  @@index([runId, status, createdAt])
}

model Job {
  id            String   @id @default(uuid())
  dealId        String
  documentId    String
  type          String
  status        String
  attemptCount  Int      @default(0)
  failureReason String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  deal     Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([dealId, documentId])
}

// Admin access, public-site support, and feedback records.

model AdminCredential {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  passwordSalt String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions AdminSession[]
}

model AdminSession {
  id           String    @id @default(uuid())
  credentialId String
  tokenHash    String    @unique
  expiresAt    DateTime
  lastSeenAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  credential AdminCredential @relation(fields: [credentialId], references: [id], onDelete: Cascade)

  @@index([credentialId, expiresAt])
  @@index([expiresAt])
}

model AppSettings {
  id                     String   @id @default("primary")
  appAccessEnabled       Boolean  @default(true)
  publicSiteEnabled      Boolean  @default(true)
  signUpsEnabled         Boolean  @default(true)
  emailDeliveryEnabled   Boolean  @default(true)
  updatedByAdminUsername String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model AnonymousAnalysisSession {
  id              String    @id @default(uuid())
  token           String    @unique
  fileName        String
  mimeType        String
  sourceType      String
  visitorId       String?
  ipHash          String?
  fileHash        String?
  storagePath     String?
  rawText         String?
  normalizedText  String
  analysisJson    Json
  breakdownJson   Json
  claimedByUserId String?
  claimedDealId   String?
  claimedAt       DateTime?
  expiresAt       DateTime
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([expiresAt])
  @@index([claimedAt, expiresAt])
  @@index([visitorId, fileHash, expiresAt])
  @@index([visitorId, createdAt])
  @@index([ipHash, createdAt])
}

model AnonymousUploadLedger {
  id        String   @id @default(uuid())
  visitorId String
  ipHash    String
  fileHash  String
  createdAt DateTime @default(now())

  @@index([visitorId, createdAt])
  @@index([ipHash, createdAt])
  @@index([visitorId, fileHash, createdAt])
}

model FeedbackSubmission {
  id                         String    @id @default(uuid())
  userId                     String
  score                      Int
  message                    String?
  pagePath                   String
  pageTitle                  String
  dealId                     String?
  requestedFollowUp          Boolean   @default(false)
  contactEmail               String
  userFollowUpEmailMessageId String?
  userFollowUpEmailSentAt    DateTime?
  supportEmailMessageId      String?
  supportEmailSentAt         DateTime?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([dealId, createdAt])
}

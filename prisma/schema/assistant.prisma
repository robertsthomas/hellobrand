// Assistant conversation and workspace snapshot records.

model AssistantThread {
  id        String   @id @default(uuid())
  userId    String
  dealId    String?
  scope     String
  title     String
  summary   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  deal     Deal?              @relation(fields: [dealId], references: [id], onDelete: Cascade)
  messages AssistantMessage[]

  @@index([userId, updatedAt])
  @@index([dealId, updatedAt])
}

model AssistantMessage {
  id        String   @id @default(uuid())
  threadId  String
  role      String
  content   String
  parts     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  thread AssistantThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}

model AssistantContextSnapshot {
  id        String   @id @default(uuid())
  userId    String
  dealId    String?
  scope     String
  key       String
  version   String
  summary   String
  payload   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  deal Deal? @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([dealId, scope])
}
